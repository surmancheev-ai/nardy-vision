{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:hosted": "next start -p 3000",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.cjs",
    "db:setup": "npm run prisma:generate && npm run db:push && npm run db:seed",
    "worker:logasai": "node scripts/logasai-worker.mjs",
    "logasai:prepare-session": "node scripts/logasai-analysis-session.mjs",
    "logasai:automate": "powershell -ExecutionPolicy Bypass -File scripts/logasai-analysis-automation.ps1",
    "logasai:capture-window": "powershell -ExecutionPolicy Bypass -File scripts/logasai-window-capture.ps1",
    "logasai:detect-status": "python scripts/logasai-status-detector.py"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.29",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.65.0",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.18.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
