generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum PlanTier {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  EXPIRED
}

enum BillingInterval {
  MONTH
  YEAR
}

enum AnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisMode {
  POSITION_IMAGE
  MATCH_PROTOCOL
}

enum ContentType {
  ARTICLE
  GUIDE
  LESSON
}

enum ContentAccessTier {
  FREE
  PRO
  PREMIUM
}

enum BillingProductType {
  SUBSCRIPTION
  POSITION_PACK
  CONTENT_ACCESS
  MATCH_ANALYSIS
}

enum PriceType {
  RECURRING
  ONE_TIME
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum CurrencyCode {
  USD
  EUR
  RUB
}

enum AnalysisCreditReason {
  SUBSCRIPTION_ALLOCATION
  ONE_TIME_PURCHASE
  ANALYSIS_CONSUMPTION
  MANUAL_ADJUSTMENT
  REFUND
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  name                String?
  passwordHash        String?
  image               String?
  role                UserRole              @default(USER)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  accounts            Account[]
  sessions            Session[]
  subscription        Subscription?
  analyses            Analysis[]
  uploadedImages      UploadedImage[]
  authoredContent     Content[]             @relation("ContentAuthor")
  purchases           Purchase[]
  contentAccessGrants ContentAccessGrant[]
  analysisCreditLog   AnalysisCreditLedger[]
}

model Subscription {
  id                    String              @id @default(cuid())
  userId                String              @unique
  planTier              PlanTier            @default(FREE)
  status                SubscriptionStatus  @default(TRIALING)
  billingInterval       BillingInterval?
  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UploadedImage {
  id            String      @id @default(cuid())
  userId        String
  storageKey    String      @unique
  originalName  String
  mimeType      String
  fileSize      Int
  width         Int?
  height        Int?
  storageUrl    String
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses      Analysis[]

  @@index([userId, createdAt])
}

model Analysis {
  id                    String         @id @default(cuid())
  userId                String
  uploadedImageId       String
  analysisMode          AnalysisMode   @default(POSITION_IMAGE)
  status                AnalysisStatus @default(QUEUED)
  engineProvider        String         @default("mock")
  engineVersion         String?
  summary               String?
  creditCost            Int            @default(1)
  recognizedPosition    Json?
  recommendations       Json?
  metrics               Json?
  rawResponse           Json?
  errorMessage          String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadedImage         UploadedImage  @relation(fields: [uploadedImageId], references: [id], onDelete: Cascade)
  creditEvents          AnalysisCreditLedger[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([uploadedImageId])
}

model Content {
  id                  String                @id @default(cuid())
  authorId            String?
  title               String
  slug                String                @unique
  excerpt             String?
  body                String
  type                ContentType
  accessTier          ContentAccessTier     @default(FREE)
  isIndividuallySold  Boolean               @default(false)
  published           Boolean               @default(false)
  publishedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  author              User?                 @relation("ContentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  billingProducts     BillingProduct[]
  accessGrants        ContentAccessGrant[]

  @@index([type, published])
  @@index([accessTier, published])
}

model BillingProduct {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  description       String?
  productType       BillingProductType
  planTier          PlanTier?
  analysisCredits   Int?
  contentId         String?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  content           Content?            @relation(fields: [contentId], references: [id], onDelete: SetNull)
  prices            BillingPrice[]
  purchaseItems     PurchaseItem[]

  @@index([productType, isActive])
}

model BillingPrice {
  id                String              @id @default(cuid())
  productId         String
  stripePriceId     String?             @unique
  type              PriceType
  amount            Int
  currency          CurrencyCode
  billingInterval   BillingInterval?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  product           BillingProduct      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isActive])
}

model Purchase {
  id                      String               @id @default(cuid())
  userId                  String
  status                  PurchaseStatus       @default(PENDING)
  currency                CurrencyCode
  totalAmount             Int
  stripePaymentIntentId   String?              @unique
  stripeCheckoutSessionId String?              @unique
  paidAt                  DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                   PurchaseItem[]
  contentAccessGrants     ContentAccessGrant[]
  analysisCreditLog       AnalysisCreditLedger[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model PurchaseItem {
  id                String              @id @default(cuid())
  purchaseId        String
  productId         String
  quantity          Int                 @default(1)
  unitAmount        Int
  totalAmount       Int
  createdAt         DateTime            @default(now())

  purchase          Purchase            @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product           BillingProduct      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
}

model ContentAccessGrant {
  id                String              @id @default(cuid())
  userId            String
  contentId         String
  purchaseId        String?
  createdAt         DateTime            @default(now())
  expiresAt         DateTime?

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  content           Content             @relation(fields: [contentId], references: [id], onDelete: Cascade)
  purchase          Purchase?           @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@unique([userId, contentId])
  @@index([purchaseId])
}

model AnalysisCreditLedger {
  id                String               @id @default(cuid())
  userId            String
  purchaseId        String?
  analysisId        String?
  delta             Int
  reason            AnalysisCreditReason
  expiresAt         DateTime?
  createdAt         DateTime             @default(now())

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase          Purchase?            @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  analysis          Analysis?            @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([purchaseId])
  @@index([analysisId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier   String
  token        String   @unique
  expires      DateTime

  @@unique([identifier, token])
}
